# ===========================
# データベース接続設定
# ===========================

# 使用するDBプロバイダー（postgresql, mysql など）
# ※ schema.prisma の provider は env() で切り替えできないので、prisma/schema.prismaのproviderの部分を変えてね

DATABASE_PROVIDER=postgresql

# PostgreSQL用の接続URL例
DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# MySQL用の接続URL例（使う場合はコメントアウトを外す）
# DATABASE_URL="mysql://user:password@localhost:3306/mydb"

# ===========================
# NextAuth.js 認証設定
# ===========================

# 認証用のシークレットキー（必須）
# 本番環境では十分に長くランダムな値を設定してください
NEXTAUTH_SECRET="your-nextauth-secret"

# 認証コールバックのURL（例: 本番URLやローカルURL）
# NEXTAUTH_URL="https://your-production-domain.com/auth"
# NEXTAUTH_URL="http://localhost:3000/auth"

# 本番URLやローカルURL
# NEXT_PUBLIC_APP_URL=http://localhost:3000